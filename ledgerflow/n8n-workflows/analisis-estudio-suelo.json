          }
        ],
        [
          {
            "node": "Obtener Cliente",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Crear Cotización": {
      "main": [
        [
          {
            "node": "Obtener Cliente",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Obtener Cliente": {
      "main": [
        [
          {
            "node": "Enviar Email Notificación",
            "type": "main",
            "index": 0
          },
          {
            "node": "Crear Reporte Cobro",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Enviar Email Notificación": {
      "main": [
        [
          {
            "node": "Log Éxito",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Crear Reporte Cobro": {
      "main": [
        [
          {
            "node": "Log Éxito",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Éxito": {
