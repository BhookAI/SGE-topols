# ============================================
# LEDGERFLOW - CONFIGURACIÓN COMPLETA
# Copiar este archivo a .env.local y completar
# ============================================

# ============================================
# SUPABASE (REQUERIDO)
# ============================================
# URL del proyecto Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon Key - para operaciones del cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key - SOLO para servidor (Settings > API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# AUTENTICACIÓN Y SEGURIDAD
# ============================================
# JWT Secret para firmar tokens personalizados (generar con: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-min-32-characters-long

# Secret para webhooks (generar string aleatorio seguro)
WEBHOOK_SECRET=your-webhook-secret-min-32-characters

# API Key para endpoints internos
API_INTERNAL_KEY=your-internal-api-key

# ============================================
# INTELIGENCIA ARTIFICIAL
# ============================================
# Proveedor: openai, openrouter, groq, anthropic
AI_PROVIDER=openrouter

# --- OpenRouter (RECOMENDADO - Más barato) ---
OPENROUTER_API_KEY=sk-or-v1-your-key
# Modelos disponibles: mistralai/mixtral-8x7b-instruct, meta-llama/llama-3.1-70b-instruct, google/gemini-pro
OPENROUTER_MODEL=mistralai/mixtral-8x7b-instruct
OPENROUTER_VISION_MODEL=google/gemini-pro-vision

# --- OpenAI (Más caro, mejor calidad) ---
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# --- Groq (Ultra rápido, buen precio) ---
GROQ_API_KEY=gsk-your-key
GROQ_MODEL=mixtral-8x7b-32768
GROQ_VISION_MODEL=llava-v1.5-7b-4096-preview

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_VISION_MODEL=claude-3-sonnet-20240229

# ============================================
# N8N - AUTOMATIZACIÓN (OPCIONAL)
# ============================================
# URL del webhook de n8n
N8N_WEBHOOK_URL=https://your-n8n.com/webhook

# Secret para verificar webhooks de n8n
N8N_SECRET=your-n8n-secret

# API Key de n8n (si tiene autenticación)
N8N_API_KEY=n8n_api_your-key

# ============================================
# SERVICIOS DE COMUNICACIÓN (OPCIONAL)
# ============================================
# --- WhatsApp (WhatsApp Business API o WhatsGW) ---
WHATSAPP_PROVIDER=whatsgw
WHATSAPP_API_KEY=your-whatsapp-key
WHATSAPP_API_URL=https://api.whatsgw.com.br
WHATSAPP_PHONE_NUMBER=your-phone-number

# --- Email (Resend - Recomendado) ---
RESEND_API_KEY=re_your-key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=LedgerFlow

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=your-twilio-number

# ============================================
# ALMACENAMIENTO Y CDN
# ============================================
# URL base para archivos (Supabase Storage)
NEXT_PUBLIC_STORAGE_URL=https://your-project.supabase.co/storage/v1/object/public

# Cloudflare R2 (opcional, para backups)
R2_ACCESS_KEY_ID=your-r2-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_BUCKET_NAME=ledgerflow-backups

# ============================================
# MONITOREO Y ANALYTICS (OPCIONAL)
# ============================================
# Vercel Analytics (automático en Vercel)
VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# Sentry para errores
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-token

# LogRocket para session replay
LOGROCKET_APP_ID=your-logrocket-id

# ============================================
# CONFIGURACIÓN DE LA APP
# ============================================
# Entorno: development, staging, production
NODE_ENV=development

# URL de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nombre de la app
NEXT_PUBLIC_APP_NAME=LedgerFlow

# Versión
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================
# FEATURE FLAGS
# ============================================
# Habilitar procesamiento con IA
ENABLE_AI_PROCESSING=true

# Habilitar notificaciones WhatsApp
ENABLE_WHATSAPP_NOTIFICATIONS=false

# Habilitar reportes automáticos
ENABLE_AUTO_REPORTS=false

# Modo debug (más logs)
DEBUG_MODE=false

# ============================================
# LÍMITES Y RATE LIMITING
# ============================================
# Máximo de documentos por minuto por tenant
RATE_LIMIT_DOCUMENTS_PER_MINUTE=10

# Máximo de requests por minuto
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Tamaño máximo de archivo (MB)
MAX_FILE_SIZE_MB=10

# ============================================
# BASE DE DATOS (SOLO PARA DESARROLLO LOCAL)
# ============================================
# Si usas PostgreSQL local en lugar de Supabase
DATABASE_URL=postgresql://user:password@localhost:5432/ledgerflow
DIRECT_URL=postgresql://user:password@localhost:5432/ledgerflow

# ============================================
# INSTRUCCIONES
# ============================================
# 1. Copiar este archivo: cp .env.local.example .env.local
# 2. Completar todas las variables marcadas como REQUERIDO
# 3. Generar secrets seguros con:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. Reiniciar el servidor después de cambios
# ============================================
